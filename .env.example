# Auth / Wallet (Privy)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Real-Time News Feeds
NEWSDATA_API_KEY=your_newsdata_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# AI - Narrative Generation
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# AI - Image Generation (FAL.ai)
FAL_KEY=your_fal_key_here
GENERATE_IMAGES=false # true = real AI images, false = Picsum placeholders
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Database (Supabase)
# Note: This project uses a custom schema: plot_news_app
DATABASE_URL="postgresql://postgres.[PROJ]:[PASS]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[PASS]@db.[PROJ].supabase.co:5432/postgres"

# Infrastructure
CRON_SECRET=your_random_cron_secret_here